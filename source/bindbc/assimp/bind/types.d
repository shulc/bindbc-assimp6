/// Hand-maintained type definitions for the assimp 6.0.5 C API.
///
/// assimp's public data types live in heavily-templated C++ headers
/// (aiVector3t!TReal etc.) that no regex can translate safely, so — unlike
/// `bind/core.d`, which is generated by tools/gen_binds.py — this module is
/// maintained by hand and audited field-by-field against the upstream headers
/// in `include/assimp/`. Layouts here must match the C ABI byte-for-byte.
///
/// Enum members use the bare (prefix-stripped) spelling, e.g.
/// `aiTextureType.DIFFUSE`. Bit-flag sets that C code uses unqualified
/// (the `aiProcess_*` post-processing steps) are kept as module-scope
/// manifest constants so they read exactly like the C names.
module bindbc.assimp.bind.types;

extern (C):

// ---------------------------------------------------------------------------
// defs.h — precision-dependent scalar aliases
// ---------------------------------------------------------------------------

version (ASSIMP_DOUBLE_PRECISION) {
    alias ai_real = double;
    alias ai_int  = long;
    alias ai_uint = ulong;
    enum ASSIMP_AI_REAL_TEXT_PRECISION = 16;
} else {
    alias ai_real = float;
    alias ai_int  = int;
    alias ai_uint = uint;
    enum ASSIMP_AI_REAL_TEXT_PRECISION = 8;
}

alias ai_int32  = int;    /// int32_t
alias ai_uint32 = uint;   /// uint32_t

alias aiBool = int;
enum AI_FALSE = 0;
enum AI_TRUE  = 1;

// ---------------------------------------------------------------------------
// math constants (defs.h)
// ---------------------------------------------------------------------------

enum AI_MATH_PI        = 3.141592653589793238462643383279;
enum AI_MATH_TWO_PI    = AI_MATH_PI * 2.0;
enum AI_MATH_HALF_PI   = AI_MATH_PI * 0.5;

enum AI_MATH_PI_F      = 3.1415926538f;
enum AI_MATH_TWO_PI_F  = AI_MATH_PI_F * 2.0f;
enum AI_MATH_HALF_PI_F = AI_MATH_PI_F * 0.5f;

enum ai_epsilon = cast(ai_real) 1e-6;

/// Convert between radians and degrees (mirror of the AI_DEG_TO_RAD macros).
alias AI_DEG_TO_RAD = x => x * cast(ai_real) 0.0174532925;
alias AI_RAD_TO_DEG = x => x * cast(ai_real) 57.2957795;

/// Maximum number of elements of `type` assimp will allocate in one block.
enum AI_MAX_ALLOC(type) = (256U * 1024 * 1024) / type.sizeof;

