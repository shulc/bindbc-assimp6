// ---------------------------------------------------------------------------
// material.h — property keys
//
// An assimp material key is the triple (name, semantic, index). Non-texture
// keys hardcode semantic = index = 0. Texture-bound keys vary the texture
// type (semantic) and slot index, so they are exposed as the
// `AI_MATKEY_TEXTURE!(type, N)`-style templates below.
// ---------------------------------------------------------------------------

struct AiMatKey {
    const(char)* key;
    uint semantic;
    uint index;
}

